---
layout: default
---

<!-- 引入学术风格衬线字体 + 手写字体 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Long+Cang&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&display=swap" rel="stylesheet">


<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <strong><span>{{ site.first_name }}</span></strong>
        <span>TAN</span>
        <span class="name-separator">·</span>
        <span class="chinese-name">{{ site.Chinese_name }}</span>
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>

    
    <!-- 社交图标 -->
    <div class="social-icons-header">
      {% if site.email %}
        <a href="mailto:{{ site.email }}" title="Email">
          <i class="fas fa-envelope"></i>
        </a>
      {% endif %}
      {% if site.github_username %}
        <a href="https://github.com/{{ site.github_username }}" title="GitHub" target="_blank">
          <i class="fab fa-github"></i>
        </a>
      {% endif %}
      {% if site.scholar_userid %}
        <a href="https://scholar.google.com/citations?user={{ site.scholar_userid }}" title="Google Scholar" target="_blank">
          <i class="ai ai-google-scholar"></i>
        </a>
      {% endif %}
      {% if site.semanticscholar_id %}
        <a href="https://www.semanticscholar.org/author/{{ site.semanticscholar_id }}" title="Semantic Scholar" target="_blank">
          <i class="ai ai-semantic-scholar"></i>
        </a>
      {% endif %}
      {% if site.cv_pdf %}
        <a href="{{ '/assets/pdf/' | append: site.cv_pdf | relative_url }}" title="CV" target="_blank">
          <i class="ai ai-cv"></i>
        </a>
      {% endif %}
      {% if site.orcid_id %}
        <a href="https://orcid.org/{{ site.orcid_id }}" title="ORCID" target="_blank">
          <i class="fab fa-orcid"></i>
        </a>
      {% endif %}
      {% if site.linkedin_username %}
        <a href="https://www.linkedin.com/in/{{ site.linkedin_username }}" title="LinkedIn" target="_blank">
          <i class="fab fa-linkedin"></i>
        </a>
      {% endif %}
      {% if site.twitter_username %}
        <a href="https://twitter.com/{{ site.twitter_username }}" title="Twitter" target="_blank">
          <i class="fab fa-twitter"></i>
        </a>
      {% endif %}
    </div>
  </header>
</div>

<article>
  {% if page.profile %}
    <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
      {% if page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        {% if page.profile.image_circular %}
          {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
        {% else %}
          {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
        {% endif %}
        {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
        {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image cache_bust=true %}
      {% endif %}
      {% if page.profile.more_info %}
        <div class="more-info">{{ page.profile.more_info }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="clearfix">{{ content }}</div>

  <!-- News -->
  {% if page.news and site.announcements.enabled %}
    <h2 id="sec-news" class="section-title">
      <span>👀 News</span>
    </h2>
    {% include news.liquid %}
  {% endif %}

  <!-- Education Experience - Logo Timeline Style -->
  <div class="timeline-section education-section">
    <h2 id="sec-education" class="section-title">
      <span>👨🏻‍🎓 Education Experience</span>
    </h2>
    <p class="timeline-expand-hint">Click a school below to expand details.</p>

    <!-- Logo Row -->
    <div class="logo-row">
      {% for education in site.data.education %}
        <div class="logo-item" onclick="toggleEducationDetail('{{ forloop.index }}')" data-index="{{ forloop.index }}">
          <img src="{{ education.logo }}" alt="{{ education.school }}" class="timeline-logo">
          <div class="logo-text-group">
            <span class="logo-label">{{ education.school }}</span>
            <span class="logo-role">{{ education.role_short | default: education.degree }}</span>
            <span class="logo-year">{{ education.year }}</span>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Detail Cards -->
    {% for education in site.data.education %}
      <div class="detail-card" id="education-detail-{{ forloop.index }}">
        <div class="detail-card-inner">
          <div class="detail-mark">
            <img src="{{ education.logo }}" alt="{{ education.school }}" class="detail-logo">
          </div>
          <div class="detail-card-content">
            <div class="detail-header">
              <div class="detail-title-group">
                <h3 class="detail-title">{{ education.school }}</h3>
                {% if education.college or education.location %}
                  <div class="detail-title-meta">
                    {% if education.college %}<span>{{ education.college }}</span>{% endif %}
                    {% if education.college and education.location %}<span class="detail-title-sep">·</span>{% endif %}
                    {% if education.location %}<span>📍 {{ education.location }}</span>{% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="detail-tags">
                <span class="detail-tag">{{ education.degree }}</span>
                <span class="detail-tag">{{ education.year }}</span>
              </div>
            </div>
            <div class="detail-fields detail-fields--education">
              {% if education.intro %}
                <div class="detail-field detail-field--wide">
                  <span class="detail-field-label">Note</span>
                  <span class="detail-field-value detail-intro-text"><em>{{ education.intro }}</em></span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- Research Experience - Logo Timeline Style -->
  <div class="timeline-section">
    <h2 id="sec-research" class="section-title">
      <span>🔬 Research Experience</span>
    </h2>
    <p class="timeline-expand-hint">Click an institution below to expand details.</p>

    <!-- Logo Row -->
    <div class="logo-row">
      {% for research in site.data.research %}
        <div class="logo-item" onclick="toggleResearchDetail('{{ forloop.index }}')" data-index="{{ forloop.index }}">
          <img src="{{ research.logo }}" alt="{{ research.institution }}" class="timeline-logo">
          <div class="logo-text-group">
            <span class="logo-lab-at">{{ research.lab_at | default: research.abbr | default: research.institution }}</span>
            <span class="logo-role">{{ research.role }}</span>
            <span class="logo-year">{{ research.period }}</span>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Detail Cards -->
    {% for research in site.data.research %}
      <div class="detail-card" id="research-detail-{{ forloop.index }}">
        <div class="detail-card-inner">
          <div class="detail-mark">
            <img src="{{ research.logo }}" alt="{{ research.institution }}" class="detail-logo">
          </div>
          <div class="detail-card-content">
            <div class="detail-header">
              <div class="detail-title-group">
                <h3 class="detail-title">{{ research.institution }}</h3>
                {% if research.lab_at or research.location %}
                  <div class="detail-title-meta">
                    {% if research.lab_at %}<span>{{ research.lab_at }}</span>{% endif %}
                    {% if research.lab_at and research.location %}<span class="detail-title-sep">·</span>{% endif %}
                    {% if research.location %}<span>📍 {{ research.location }}</span>{% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="detail-tags">
                <span class="detail-tag">{{ research.role }}</span>
                <span class="detail-tag">{{ research.period }}</span>
              </div>
            </div>
            <div class="detail-fields detail-fields--research">
              {% if research.lab %}
                <div class="detail-field detail-field--medium">
                  <span class="detail-field-label">Lab</span>
                  <span class="detail-field-value">
                    {% assign lab = research.lab %}
                    {% if lab.url and lab.url != "" %}
                      {% assign lab_parts = lab.name | split: "（" %}
                      {% if lab_parts.size > 1 %}
                        <a href="{{ lab.url }}" target="_blank">{{ lab_parts[0] }}<span class="chinese-handwriting">（{{ lab_parts[1] }}</span></a>
                      {% else %}
                        <a href="{{ lab.url }}" target="_blank">{{ lab.name }}</a>
                      {% endif %}
                    {% elsif lab.name %}
                      {% assign lab_parts = lab.name | split: "（" %}
                      {% if lab_parts.size > 1 %}
                        {{ lab_parts[0] }}<span class="chinese-handwriting">（{{ lab_parts[1] }}</span>
                      {% else %}
                        {{ lab.name }}
                      {% endif %}
                    {% else %}
                      {{ lab }}
                    {% endif %}
                  </span>
                </div>
              {% endif %}

              {% if research.coauthor_links or research.co-authors %}
                <div class="detail-field detail-field--wide">
                  <span class="detail-field-label">Co-authors</span>
                  <span class="detail-field-value">
                    {% if research.coauthor_links %}
                      {% for person in research.coauthor_links %}{% if person.url and person.url != "" %}<a href="{{ person.url }}" target="_blank">{{ person.name }}</a>{% else %}{{ person.name }}{% endif %}{% unless forloop.last %}, {% endunless %}{% endfor %}
                    {% elsif research.co-authors %}
                      {{ research.co-authors | join: ", " }}
                    {% endif %}
                  </span>
                </div>
              {% endif %}

              {% if research.outputs %}
                <div class="detail-field detail-field--wide">
                  <span class="detail-field-label">Works</span>
                  <span class="detail-field-value">
                    {% for output in research.outputs %}
                      {% if output.url and output.url != "" %}
                        <a href="{{ output.url }}" target="_blank" class="output-link">{{ output.name }}</a>{% unless forloop.last %}, {% endunless %}
                      {% else %}
                        <span class="output-text">{{ output.name }}</span>{% unless forloop.last %}, {% endunless %}
                      {% endif %}
                    {% endfor %}
                  </span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>


  <!-- Selected papers -->
  {% if page.selected_papers %}
    <h2 id="sec-publications" class="section-title">
      <span>📖 Selected Publications</span>
    </h2>
    {% include selected_papers.liquid %}
  {% endif %}

  <!-- Selected Honors -->
  {% if site.latest_posts.enabled %}
    <h2 id="sec-honors" class="section-title">
      <span>🌟 Selected Honors</span>
    </h2>
    <div class="honors-section">
      <details class="compact-card">
        <summary><span class="compact-title">ICML Gold Reviewer</span><span class="year">2026</span></summary>
        <div class="compact-card-body">Top Reviewer at International Conference on Machine Learning.</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Tencent Scholarship</span><span class="year">2025</span></summary>
        <div class="compact-card-body">Top 2.5% at Southeast University (¥9,000).</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">First-Class Academic Scholarship</span><span class="year">2025</span></summary>
        <div class="compact-card-body">Top 10% at Southeast University (¥12,000).</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Outstanding Graduate Representative</span><span class="year">2024</span></summary>
        <div class="compact-card-body">Speaker in graduation.</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Honor Bachelor Degree</span><span class="year">2024</span></summary>
        <div class="compact-card-body">Top 3% at Shenzhen University.</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Outstanding Graduate</span><span class="year">2024</span></summary>
        <div class="compact-card-body">Top 5% at Shenzhen University.</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Star of Liyuan</span><span class="year">2022, 2023</span></summary>
        <div class="compact-card-body">Top 0.73% at Shenzhen University ("Liyuan" means Shenzhen University, ¥20,000).</div>
      </details>
      <details class="compact-card">
        <summary><span class="compact-title">Scholarship of Outstanding Innovative Talent</span><span class="year">2020</span></summary>
        <div class="compact-card-body">Top 2% in Guangdong Province Science College Entrance Exam (¥20,000).</div>
      </details>
    </div>
  {% endif %}

  <!-- Teaching Assistant -->
  <h2 id="sec-teaching" class="section-title">
    <span>💡 Teaching Assistant</span>
  </h2>
  <div class="teaching-section">
    <details class="compact-card">
      <summary><span class="compact-title">Fundamentals of Programming</span><span class="year">2022 Fall</span></summary>
      <div class="compact-card-body">2022 Mathematics and Computer Science Special Class, WeBank Fintech Class.</div>
    </details>
    <details class="compact-card">
      <summary><span class="compact-title">Data Structure</span><span class="year">2022 Fall, 2023 Fall</span></summary>
      <div class="compact-card-body">2021 and 2022 Computer Science Classes.</div>
    </details>
    <details class="compact-card">
      <summary><span class="compact-title">Object-Oriented Programming</span><span class="year">2023 Spring, 2024 Spring</span></summary>
      <div class="compact-card-body">2022 Mathematics and Computer Science Special Class, WeBank Fintech Class, 2023 Computer Science Class.</div>
    </details>
    <details class="compact-card">
      <summary><span class="compact-title">Computer System</span><span class="year">2023 Spring</span></summary>
      <div class="compact-card-body">2022 Mathematics and Computer Science Special Class.</div>
    </details>
    <details class="compact-card">
      <summary><span class="compact-title">Introduction to Computer Science</span><span class="year">2023 Fall</span></summary>
      <div class="compact-card-body">Common Optional Course.</div>
    </details>
    <details class="compact-card">
      <summary><span class="compact-title">Operating System</span><span class="year">2024 Spring</span></summary>
      <div class="compact-card-body">2021 Computer Science Class.</div>
    </details>
  </div>

  <!-- Service -->
  <h2 id="sec-service" class="section-title">
    <span>📋 Service</span>
  </h2>
  <div class="service-section">
    <ul class="service-list">
      <li>
        <span class="service-role">Conference Reviewer</span>
        <span class="service-details">ICML 2026 <span class="service-note">(Gold Reviewer)</span>, NeurIPS 2026.</span>
      </li>
    </ul>
  </div>

  <!-- Life -->
  {% comment %}
  <h2 id="sec-life" class="section-title">
    <span>🏠 Life</span>
  </h2>
  <div class="hobbies-section">
    <p class="hobbies-intro">
      I have a passion for exploring the underlying principles of the world, not only in my research but also across natural sciences, engineering, and social humanities. Beyond academics, I find quiet joy and inspiration in the arts. I practice hard-pen calligraphy (especially admiring the works of <a href="https://baike.baidu.com/item/%E9%A1%BE%E4%BB%B2%E5%AE%89/7536674" target="_blank"><em>Zhong'an Gu</em></a>), visit exhibitions, and listen to Cantonese pop (e.g., <a href="https://music.youtube.com/watch?v=ZXM7rRMnA7U&si=3CNV8lIUn0mGRrDY" target="_blank"><em>Peach Blossom Island</em></a> and <a href="https://music.youtube.com/watch?v=7O8YDJen5bs&si=FlTYVwFlUnp_3rp3" target="_blank"><em>The One For U</em></a> by <em>MC</em>) as well as Chinese pop music (e.g., <a href="https://music.youtube.com/watch?v=p4hxF-8HefE" target="_blank"><em>Cang Jie</em></a> and <a href="https://music.youtube.com/watch?v=FW2W9HM7IPs&si=HhjEKeAfYmNL7GLf" target="_blank"><em>Step by Step</em></a> by <em>Mayday</em>). I also stay active with table tennis (big fan of <a href="https://zh.wikipedia.org/zh-hk/%E6%A8%8A%E6%8C%AF%E4%B8%9C" target="_blank"><em>Zhendong Fan</em></a>) and badminton. Oh, and one more thing: I have been a huge fan of <a href="https://en.wikipedia.org/wiki/Doraemon" target="_blank"><em>Doraemon</em></a> since childhood!
    </p>
  </div>

  <!-- Blog -->
  <h2 id="sec-blog" class="section-title">
    <span>📝 Blog</span>
    <span style="margin-left: 0.5rem; font-size: 0.75rem; color: #c09c6b; background: rgba(192, 156, 107, 0.15); padding: 0.2rem 0.5rem; border-radius: 12px; font-weight: 600;">coming soon</span>
  </h2>
  <div style="padding: 0.5rem 0; color: #8b949e; font-size: 0.9rem;">
    Share thoughts on research, technology, and life insights.
  </div>
  {% endcomment %}

  <!-- Social -->
  {% if page.social %}
    <div class="social">
      <div class="contact-icons">{% include social.liquid %}</div>
      <div class="contact-note">{{ site.contact_note }}</div>
    </div>
  {% endif %}

  {% if site.newsletter.enabled and site.footer_fixed %}
    {% include scripts/newsletter.liquid center=true %}
  {% endif %}

  <!-- Page-level Last Updated -->
  <div class="page-last-updated">
    Last updated: {{ site.time | date: '%B %d, %Y' }}
  </div>
</article>

<!-- 交互式卡通人物（可切换：哆啦A梦、Tom & Jerry、Hello Kitty、皮卡丘） -->
<!-- 双击切换角色，单击显示对话 -->
<div id="mascot-container">
  <!-- 哆啦A梦（精灵图走路动画版） -->
  <div id="doraemon" class="mascot active"></div>
  
  <!-- Tom & Jerry -->
  <div id="tomjerry" class="mascot">
    <img src="https://4.bp.blogspot.com/-HjOu-dGh2P4/UAv31SSQYQI/AAAAAAAAA3g/a9flM74pDqQ/s1600/Tom-and-jerry-psd57584.png" alt="Tom & Jerry">
  </div>
  
  <!-- 对话气泡 -->
  <div id="mascot-bubble" class="mascot-bubble"></div>
  <!-- 操作提示 -->
  <div class="mascot-hint">Click: talk · Double-click: switch</div>
</div>




<!-- About-page custom scripts: mascot, scroll-spy subnav, education/research toggles, oneko (disabled) -->
<script src="{{ '/assets/js/custom.js' | relative_url }}" defer></script>

