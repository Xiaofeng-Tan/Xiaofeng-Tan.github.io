  /* ========== 对话气泡样式 ========== */
  .mascot-bubble {
    position: absolute;
    top: 0;
    left: 50%;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 12px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #2c3e50;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);
    opacity: 0;
    transform: translateX(-50%) translateY(-8px) scale(0.9);
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    pointer-events: none;
    white-space: nowrap;
    border: 2px solid var(--bubble-border-color, #0DACD6);
    z-index: 10;
    width: fit-content;
    max-width: 90vw;
    min-width: 140px;
    line-height: 1.4;
  }
  
  /* 气泡箭头指向下方（角色） */
  .mascot-bubble::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 10px 8px 0 8px;
    border-style: solid;
    border-color: var(--bubble-border-color, #0DACD6) transparent transparent transparent;
  }
  
  .mascot-bubble::before {
    content: '';
    position: absolute;
    bottom: -7px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 8px 6px 0 6px;
    border-style: solid;
    border-color: var(--bubble-bg-color, #ffffff) transparent transparent transparent;
    z-index: 1;
  }
  
  .mascot-bubble.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  
  /* 对话框离场时覆盖 show 的样式 - 使用 JS 控制 */
  .mascot-bubble.show.exit-animation {
    opacity: 1;
    /* left 由 JavaScript 动态更新 */
  }
  
  /* 暗色模式 - 气泡 */
  html[data-theme="dark"] .mascot-bubble {
    background: linear-gradient(135deg, #1e2328 0%, #161b22 100%);
    color: #e6edf3;
    border-color: #5ec8f2;
  }
  
  html[data-theme="dark"] .mascot-bubble::after {
    border-color: var(--bubble-border-color, #5ec8f2) transparent transparent transparent;
  }
  
  html[data-theme="dark"] .mascot-bubble::before {
    border-color: var(--bubble-bg-color, #1e2328) transparent transparent transparent;
  }
  
  /* ========== 操作提示样式 ========== */
  .mascot-hint {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    color: #9ca3af;
    white-space: nowrap;
    opacity: 0.7;
    transition: opacity 0.3s ease;
    pointer-events: none;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  }
  
  #mascot-container:hover .mascot-hint {
    opacity: 1;
  }
  
  html[data-theme="dark"] .mascot-hint {
    color: #6b7280;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  
  /* ========== 移动端适配 ========== */
  @media (max-width: 768px) {
    #mascot-container {
      bottom: 15px;
      left: 15px;
      width: 100px;
      height: 170px;  /* 调整高度容纳气泡和提示 */
