  /* ========== 研究兴趣与联系卡片 ========== */
  .interest-card {
    margin: 0.8rem 0;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  .interest-card strong {
    background: linear-gradient(135deg, rgba(0, 161, 233, 0.12) 0%, rgba(0, 130, 200, 0.12) 100%);
    color: #00A1E9;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .interest-card .copyable {
    color: #00A1E9;
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 1px dashed rgba(0, 161, 233, 0.5);
    position: relative;
  }

  .interest-card .copyable:hover {
    color: #0082C8;
    border-bottom-color: #0082C8;
  }

  .interest-card .copyable i {
    font-size: 0.85em;
    margin-left: 0.3rem;
    opacity: 0.8;
    transition: all 0.2s ease;
    color: #00A1E9;
  }

  .interest-card .copyable:hover i {
    opacity: 1;
    transform: scale(1.1);
  }

  .interest-card em {
    font-family: "Crimson Pro", Georgia, serif;
    font-style: italic;
    color: #764ba2;
  }

  .interest-card .doraemon-text {
    color: #00A1E9;
  }

  .interest-card .doraemon-text em {
    font-family: "Crimson Pro", Georgia, serif;
    color: #00A1E9;
    font-style: italic;
  }

  /* 复制成功提示 */
  .copy-toast {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-100px);
    background: linear-gradient(135deg, #00A1E9 0%, #0082C8 100%);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    box-shadow: 0 4px 15px rgba(0, 161, 233, 0.3);
    z-index: 9999;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .copy-toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
  /* ========== 响应式设计 - 平板端 ========== */
