  /* ========== 荣誉奖项样式（带滚动条）========== */
  .honors-section {
    margin-bottom: 0.6rem;
    max-height: 160px;
    overflow-y: auto;
    padding-right: 6px;
  }

  .honors-section::-webkit-scrollbar {
    width: 3px;
  }

  .honors-section::-webkit-scrollbar-track {
    background: transparent;
  }

  .honors-section::-webkit-scrollbar-thumb {
    background: #e0e0e0;
    border-radius: 10px;
  }

  .honors-section::-webkit-scrollbar-thumb:hover {
    background: #bdbdbd;
  }

  .honors-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .honors-list li {
    padding: 0.35rem 0 0.35rem 1.6rem;
    margin-bottom: 0.25rem;
    border-left: 2px solid rgba(255, 215, 0, 0.6);
    transition: all 0.3s ease;
    position: relative;
    background: rgba(255, 215, 0, 0.03);
    border-radius: 0 6px 6px 0;
  }

  .honors-list li::before {
    content: '🏆';
    position: absolute;
    left: 0.3rem;
    top: 0.35rem;
    font-size: 0.75rem;
    transition: transform 0.3s ease;
  }

  .honors-list li:hover {
    border-left-color: rgba(255, 183, 0, 0.8);
    padding-left: 1.8rem;
    background: rgba(255, 215, 0, 0.06);
  }

  .honors-list li:hover::before {
    transform: scale(1.1) rotate(10deg);
  }

  .honor-title {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.1rem;
    flex-wrap: wrap;
  }

  .honor-title strong {
    color: #2c3e50;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .year-right {
    color: #7f8c8d;
    font-weight: 600;
    font-size: 0.68rem;
    margin-left: 0.5rem;
    background: rgba(0, 0, 0, 0.03);
    padding: 0.1rem 0.4rem;
    border-radius: 8px;
  }

  .honor-details {
    font-size: 0.72rem;
    color: #5a6c7d;
    line-height: 1.3;
  }

  /* ========== 助教经历样式（带滚动条）========== */
  .teaching-section {
    margin-bottom: 0.6rem;
    max-height: 160px;
    overflow-y: auto;
    padding-right: 6px;
  }

  .teaching-section::-webkit-scrollbar {
    width: 3px;
  }

  .teaching-section::-webkit-scrollbar-track {
    background: transparent;
  }

  .teaching-section::-webkit-scrollbar-thumb {
