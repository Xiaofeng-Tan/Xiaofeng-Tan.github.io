  html[data-theme="dark"] .interest-card .copyable:hover {
    color: #79d4f8;
  }

  html[data-theme="dark"] .interest-card .copyable i {
    color: #5ec8f2;
  }

  html[data-theme="dark"] .interest-card .doraemon-text {
