  /* ========================================== */
  /* ========== 暗色模式 - 完整重设计 ========== */
  /* ========================================== */
  /* 
   * 设计原则：与亮色模式形成优雅对偶
   * 亮色：浅色背景 + 深色文字 + 蓝色强调
   * 暗色：深色背景 + 浅色文字 + 青蓝色强调
   * 
   * 主色调对偶：
   * - 亮色主色 #00A1E9 → 暗色主色 #5ec8f2 (更亮的青蓝)
   * - 亮色强调 #764ba2 → 暗色强调 #b388ff (淡紫)
   * - 亮色背景 #fdfbfb → 暗色背景 #0d1117 (GitHub Dark)
   * - 亮色卡片 rgba(255,255,255,0.65) → 暗色卡片 rgba(22,27,34,0.85)
   */

  /* ===== 全局基础 ===== */
  html[data-theme="dark"] body {
    background: linear-gradient(135deg, #0d1117 0%, #161b22 50%, #0d1117 100%);
    animation: backgroundShiftDark 20s ease-in-out infinite;
  }

  html[data-theme="dark"] body::before {
    background: radial-gradient(circle, rgba(94, 200, 242, 0.12) 0%, transparent 70%);
  }

  html[data-theme="dark"] body::after {
    background: radial-gradient(circle, rgba(179, 136, 255, 0.1) 0%, transparent 70%);
  }

  html[data-theme="dark"] .post {
    color: #c9d1d9;
  }

  html[data-theme="dark"] article > .clearfix p,
  html[data-theme="dark"] article > .clearfix .interest-card {
    color: #c9d1d9;
  }

  /* ===== 页面标题 ===== */
  html[data-theme="dark"] .post-title {
    color: #e6edf3;
  }

  html[data-theme="dark"] .post-title strong {
    color: #ffffff;
  }

  html[data-theme="dark"] .post-title .name-separator {
    color: rgba(139, 148, 158, 0.6);
  }

  html[data-theme="dark"] .desc {
    color: #8b949e;
  }

  html[data-theme="dark"] .desc a {
    color: #5ec8f2;
  }

  html[data-theme="dark"] .desc a:hover {
    color: #79d4f8;
  }

  /* ===== 社交图标 ===== */
  html[data-theme="dark"] .social-icons-header a {
    color: #8b949e;
    border-color: rgba(139, 148, 158, 0.3);
  }

  html[data-theme="dark"] .social-icons-header a:hover {
    color: #5ec8f2;
    border-color: rgba(94, 200, 242, 0.5);
    background: rgba(94, 200, 242, 0.1);
  }

  /* ===== 章节标题 ===== */
  html[data-theme="dark"] .section-title {
    color: #e6edf3;
    border-bottom-color: rgba(94, 200, 242, 0.2);
  }

  html[data-theme="dark"] .section-title::before {
    background: linear-gradient(135deg, #5ec8f2 0%, #b388ff 100%);
  }

  html[data-theme="dark"] .section-title:hover {
