            <span class="year-right">2024</span>
          </div>
          <div class="honor-details">
            Speaker in graduation
          </div>
        </li>
        <li>
          <div class="honor-title">
            <strong><span>Honor Bachelor's Degree</span></strong>
            <span class="year-right">2024</span>
          </div>
          <div class="honor-details">
