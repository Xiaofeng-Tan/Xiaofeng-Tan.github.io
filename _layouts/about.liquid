---
layout: default
---

<!-- 引入学术风格衬线字体 + 手写字体 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Long+Cang&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&display=swap" rel="stylesheet">

<style>
  /* 顾仲安行书 - 子集化字体 */
  @font-face {
    font-family: 'Gu Xingshu';
    src: url('/assets/fonts/gu-xingshu-subset.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  /* ========== 全局样式与动画 ========== */
  body {
    background: linear-gradient(135deg, #fdfbfb 0%, #f7f4f9 50%, #faf8fc 100%);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    animation: backgroundShiftLight 20s ease-in-out infinite;
    font-family: "Crimson Pro", "Source Serif 4", Georgia, "Times New Roman", serif;
  }

  @keyframes backgroundShiftLight {
    0%, 100% { 
      background: linear-gradient(135deg, #fdfbfb 0%, #f7f4f9 50%, #faf8fc 100%);
    }
    50% { 
      background: linear-gradient(135deg, #faf8fc 0%, #fdfbfb 50%, #f7f4f9 100%);
    }
  }

  @keyframes backgroundShiftDark {
    0%, 100% { 
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
    }
    50% { 
      background: linear-gradient(135deg, #16213e 0%, #1a1a2e 50%, #16213e 100%);
    }
  }

  /* 全局浮动装饰元素 */
  body::before,
  body::after {
    content: '';
    position: fixed;
    border-radius: 50%;
    opacity: 0.4;
    z-index: 0;
    pointer-events: none;
  }

  body::before {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 161, 233, 0.1) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: floatBubble1 25s ease-in-out infinite;
  }

  body::after {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(118, 75, 162, 0.08) 0%, transparent 70%);
    bottom: -80px;
    left: -80px;
    animation: floatBubble2 30s ease-in-out infinite;
  }

  @keyframes floatBubble1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-50px, 50px) scale(1.1); }
  }

  @keyframes floatBubble2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(50px, -50px) scale(1.15); }
  }

  .post {
    font-family: "Crimson Pro", "Source Serif 4", Georgia, "Times New Roman", serif;
    color: #2c3e50;
    position: relative;
    z-index: 1;
  }

  /* About 正文段落样式 - 与 Publications 标题一致 */
  article > .clearfix p,
  article > .clearfix .interest-card {
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #2c3e50;
  }

  article > .clearfix a {
    color: #00A1E9;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  article > .clearfix a:hover {
    color: #764ba2;
  }

  /* ========== 页面标题区域（左对齐、与正文对齐，无背景）========== */
  .post-header {
    text-align: left;
    margin: 0 0 1rem 0;
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    position: relative;
    overflow: visible;
    backdrop-filter: none;
    border-radius: 0;
  }

  .post-header::before {
    content: none;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-30px, -30px) rotate(180deg); }
  }

  .post-title {
    font-family: "Dancing Script", cursive;
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    color: #4a5a6a;
    font-weight: 600;
    letter-spacing: 0.5px;
    line-height: 1.3;
    display: inline-block;
    position: relative;
  }

  .post-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: linear-gradient(90deg, 
      transparent 0%, 
      rgba(0, 161, 233, 0.3) 10%, 
      #00A1E9 50%,
      rgba(0, 161, 233, 0.3) 90%, 
      transparent 100%);
    border-radius: 1px;
  }

  .post-title strong {
    color: #5c6773;
  }

  .desc {
    font-size: 1.05rem;
    color: #7f8c8d;
    margin-top: 0.3rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .desc a {
    color: #00A1E9;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .desc a:hover {
    color: #764ba2;
  }

  /* ========== 社交图标样式 ========== */
  .social-icons-header {
    display: flex;
    justify-content: flex-start;
    gap: 0.6rem;
    margin-top: 0.8rem;
    position: relative;
    z-index: 1;
  }

  .social-icons-header a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: transparent;
    border-radius: 50%;
    color: #8b95a5;
    font-size: 0.85rem;
    transition: all 0.25s ease;
    border: 1px solid rgba(139, 149, 165, 0.15);
  }

  .social-icons-header a:hover {
    transform: translateY(-1px);
    color: #00A1E9;
    border-color: rgba(0, 161, 233, 0.3);
    background: rgba(0, 161, 233, 0.05);
  }

  /* ========== 通用章节标题样式（紧凑）========== */
  .section-title {
    font-family: "Playfair Display", Georgia, "Times New Roman", serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: #2c3e50;
    margin-top: 1.2rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    padding-left: 1rem;
    border-bottom: 2px solid rgba(0, 161, 233, 0.1);
    display: flex;
    align-items: center;
    position: relative;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .section-title:hover {
    color: #00A1E9;
  }

  .section-title::before {
    content: '';
    width: 3px;
    height: 1.1rem;
    background: linear-gradient(135deg, #00A1E9 0%, #764ba2 100%);
    margin-right: 0.6rem;
    border-radius: 2px;
    position: absolute;
    box-shadow: 0 2px 6px rgba(0, 161, 233, 0.2);
    left: 0;
  }

  /* ========== 教育经历样式 ========== */
  .education-section {
    margin-top: 0.3rem;
    margin-bottom: 0.8rem;
  }

  .education-list {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .education-item {
    background: rgba(255, 255, 255, 0.75);
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 161, 233, 0.06);
    padding: 0.65rem 1rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    transition: all 0.25s ease;
    border: 1px solid rgba(0, 161, 233, 0.1);
    position: relative;
    overflow: hidden;
  }

  .education-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 161, 233, 0.12);
    border-color: rgba(0, 161, 233, 0.25);
    background: rgba(255, 255, 255, 0.9);
  }

  .education-logo {
    width: 56px;
    height: 56px;
    margin-right: 0.9rem;
    flex-shrink: 0;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    transition: transform 0.25s ease;
  }

  .education-item:hover .education-logo {
    transform: scale(1.05);
  }

  .education-details {
    flex-grow: 1;
    position: relative;
    z-index: 1;
  }

  .education-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .education-school {
    font-size: 0.95rem;
    font-weight: 600;
    color: #2c3e50;
    transition: color 0.25s ease;
  }

  .education-item:hover .education-school {
    color: #00A1E9;
  }

  .education-degree,
  .education-location {
    font-size: 0.68rem;
    font-weight: 500;
    margin-left: 0.35rem;
    padding: 0.1rem 0.45rem;
    border-radius: 10px;
    letter-spacing: 0.01em;
  }

  .education-degree {
    color: #6366f1;
    background: rgba(99, 102, 241, 0.1);
  }

  .education-location {
    color: #64748b;
    background: rgba(100, 116, 139, 0.1);
  }

  .education-year {
    font-size: 0.68rem;
    color: #0891b2;
    font-weight: 500;
    background: rgba(8, 145, 178, 0.1);
    padding: 0.1rem 0.45rem;
    border-radius: 10px;
  }

  .education-college {
    font-size: 0.75rem;
    color: #7f8c8d;
    margin: 0.15rem 0;
    line-height: 1.35;
  }

  .education-intro {
    font-size: 0.78rem;
    color: #5a6c7d;
    line-height: 1.4;
    margin: 0;
  }

  /* ========== 研究经历样式 ========== */
  .research-section {
    margin-top: 0.3rem;
    margin-bottom: 0.8rem;
  }

  .research-list {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .research-item {
    background: rgba(255, 255, 255, 0.75);
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 161, 233, 0.06);
    padding: 0.65rem 1rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: flex-start;
    transition: all 0.25s ease;
    border: 1px solid rgba(0, 161, 233, 0.1);
    position: relative;
    overflow: hidden;
  }

  .research-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 161, 233, 0.12);
    border-color: rgba(0, 161, 233, 0.25);
    background: rgba(255, 255, 255, 0.9);
  }

  .research-logo {
    width: 56px;
    height: 56px;
    margin-right: 0.9rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    transition: transform 0.25s ease;
  }

  .research-item:hover .research-logo {
    transform: scale(1.05);
  }

  .research-details {
    flex-grow: 1;
  }

  .research-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .research-institution {
    font-size: 0.95rem;
    font-weight: 600;
    color: #2c3e50;
    transition: color 0.25s ease;
  }

  .research-item:hover .research-institution {
    color: #00A1E9;
  }

  .research-role,
  .research-location {
    font-size: 0.68rem;
    font-weight: 500;
    margin-left: 0.35rem;
    padding: 0.1rem 0.45rem;
    border-radius: 10px;
    letter-spacing: 0.01em;
  }

  .research-role {
    color: #059669;
    background: rgba(5, 150, 105, 0.1);
  }

  .research-location {
    color: #64748b;
    background: rgba(100, 116, 139, 0.1);
  }

  .research-period {
    font-size: 0.68rem;
    color: #0891b2;
    font-weight: 500;
    background: rgba(8, 145, 178, 0.1);
    padding: 0.1rem 0.45rem;
    border-radius: 10px;
  }

  .research-info {
    font-size: 0.76rem;
    color: #5a6c7d;
    margin-bottom: 0.25rem;
    line-height: 1.4;
    display: flex;
    flex-wrap: nowrap;
    align-items: baseline;
  }

  .research-lab {
    color: #5a6c7d;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 220px;
    width: 220px;
  }

  .research-info-separator {
    color: #d0d0d0;
    margin: 0 0.4rem;
    flex-shrink: 0;
  }

  .research-coauthors {
    color: #5a6c7d;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .research-lab a {
    color: #00A1E9;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .research-lab a:hover {
    color: #0082C8;
    text-decoration: underline;
  }

  /* 中文手写体样式 */
  .chinese-handwriting {
    font-family: 'Gu Xingshu', "Long Cang", cursive;
    font-weight: 400;
  }

  /* 标题中的中文名字 - 与英文对称 */
  .post-title .chinese-name {
    font-family: 'Gu Xingshu', "Long Cang", cursive;
    font-size: 0.85em;
    font-weight: 400;
    vertical-align: baseline;
    position: relative;
    top: 0.05em;
  }

  /* 中点分隔符 - 优雅居中 */
  .post-title .name-separator {
    font-family: inherit;
    font-size: 0.7em;
    color: rgba(74, 90, 106, 0.5);
    margin: 0 0.3em;
    vertical-align: middle;
    position: relative;
    top: -0.05em;
  }

  .research-lab strong,
  .research-coauthors strong {
    color: #2c3e50;
    font-weight: 600;
  }

  .research-output-section {
    margin-top: 0.2rem;
    padding-top: 0.2rem;
    border-top: 1px dashed rgba(0, 161, 233, 0.15);
    font-size: 0.76rem;
    color: #5a6c7d;
  }

  .research-output-section strong {
    color: #64748b;
    font-weight: 600;
  }

  .research-output-link {
    color: #00A1E9;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .research-output-link:hover {
    color: #0082C8;
    text-decoration: underline;
  }

  .research-output-text {
    color: #64748b;
  }

  /* ========== 新闻动态样式（紧凑、浅色）========== */
  .news {
    max-height: 240px;
    overflow-y: auto;
    padding-right: 6px;
    margin-bottom: 0.6rem;
  }

  .news::-webkit-scrollbar {
    width: 3px;
  }

  .news::-webkit-scrollbar-track {
    background: transparent;
  }

  .news::-webkit-scrollbar-thumb {
    background: #e0e0e0;
    border-radius: 10px;
  }

  .news::-webkit-scrollbar-thumb:hover {
    background: #bdbdbd;
  }

  /* 新闻列表样式 - 紧凑、清爽 */
  .news table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .news table tr {
    background: transparent;
    transition: all 0.2s ease;
    display: block;
    margin-bottom: 0.15rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .news table tr:last-child {
    border-bottom: none;
  }

  .news table tr:hover {
    background: #fafbfc;
    padding-left: 0.4rem;
  }

  .news table tr th {
    display: inline-block;
    width: auto;
    min-width: 80px;
    max-width: 80px;
    padding: 0.1rem 0.4rem;
    background: #e0f4fc;
    color: #00A1E9;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 500;
    margin-right: 0.5rem;
    vertical-align: middle;
    text-align: center;
    white-space: nowrap;
  }

  .news table tr td {
    display: inline;
    font-size: 0.82rem;
    color: #2c3e50;
    line-height: 1.4;
    vertical-align: middle;
  }

  .news table tr td p {
    display: inline;
    margin: 0;
  }

  .news table tr td a {
    color: #00A1E9;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .news table tr td a:hover {
    color: #0082C8;
  }

  .news table tr td em {
    color: #5a6c7d;
    font-style: normal;
    font-size: 0.72rem;
    margin-left: 0.4rem;
  }

  /* ========== Publications 样式（美化版）========== */
  .publications {
    margin-bottom: 0.6rem;
  }

  .publications .bibliography {
    margin-top: 0;
  }

  .publications .bibliography li {
    margin-bottom: 0.25rem;
    padding: 0.35rem 0.8rem;
    background: rgba(255, 255, 255, 0.65);
    border-radius: 10px;
    box-shadow: 0 2px 6px rgba(0, 161, 233, 0.05);
    border: 1px solid rgba(0, 161, 233, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: visible;
    backdrop-filter: blur(10px);
    width: 100%;
    min-width: 0;
  }

  .publications .bibliography li .row {
    display: flex;
    flex-wrap: nowrap;
    width: 100%;
  }

  .publications .bibliography li .col-sm-8,
  .publications .bibliography li .col-sm-10 {
    flex: 1;
    max-width: none;
    width: auto;
  }

  .publications .bibliography li::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 161, 233, 0.06) 0%, rgba(118, 75, 162, 0.06) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .publications .bibliography li:hover::before {
    opacity: 1;
  }

  .publications .bibliography li:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 161, 233, 0.1);
    border-color: rgba(0, 161, 233, 0.2);
    background: rgba(255, 255, 255, 0.8);
  }

  /* 当 abstract 或 mycomment 展开时，禁用 hover 的 transform 效果 */
  .publications .bibliography li:has(.hidden.open):hover {
    transform: none;
  }

  .publications .bibliography li:last-child {
    margin-bottom: 0;
  }

  .publications .title {
    font-size: 0.92rem;
    font-weight: 600;
    margin-bottom: 0.1rem;
    color: #2c3e50;
    line-height: 1.4;
    position: relative;
    z-index: 1;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
    letter-spacing: -0.01em;
    width: 100%;
  }

  .publications .author {
    font-size: 0.8rem;
    margin-bottom: 0.1rem;
    color: #5a6c7d;
    position: relative;
    z-index: 1;
    line-height: 1.35;
  }

  .publications .author em {
    font-weight: 700;
    font-style: normal;
    color: #00A1E9;
    background: linear-gradient(135deg, #00A1E9 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .publications .author em sup,
  .publications .author sup {
    -webkit-text-fill-color: #00A1E9;
    color: #00A1E9;
    font-size: 0.7em;
    vertical-align: super;
  }

  .publications .periodical {
    font-family: "Crimson Pro", Georgia, "Times New Roman", serif;
    font-size: 0.78rem;
    margin-bottom: 0.1rem;
    color: #7f8c8d;
    font-style: italic;
    position: relative;
    z-index: 1;
    line-height: 1.25;
  }

  .publications .periodical .venue-abbr {
    font-style: normal;
    font-weight: 600;
    margin-right: 0.3rem;
    font-size: 0.75rem;
  }

  .publications .periodical .venue-separator {
    color: #ccc;
    margin: 0 0.4rem;
    font-style: normal;
  }

  /* CCF 等级徽章 */
  .ccf-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-left: 0.4rem;
    font-style: normal;
    vertical-align: middle;
  }

  .ccf-badge-ccfa {
    background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(238, 90, 90, 0.3);
  }

  .ccf-badge-ccfb {
    background: linear-gradient(135deg, #ffa726 0%, #fb8c00 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(251, 140, 0, 0.3);
  }

  .ccf-badge-ccfc {
    background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(67, 160, 71, 0.3);
  }

  .ccf-badge-ccfnone {
    background: linear-gradient(135deg, #90a4ae 0%, #78909c 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(120, 144, 156, 0.3);
  }

  /* CORE 等级徽章 */
  .core-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-left: 0.4rem;
    font-style: normal;
    vertical-align: middle;
  }

  .core-badge-coreastar {
    background: linear-gradient(135deg, #7c4dff 0%, #651fff 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(101, 31, 255, 0.3);
  }

  .core-badge-corea {
    background: linear-gradient(135deg, #448aff 0%, #2979ff 100%);
    color: white;
    box-shadow: 0 2px 4px rgba(41, 121, 255, 0.3);
  }

